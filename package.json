{
  "name": "world42",
  "version": "0.0.5",
  "scripts": {
    "serve": "rspack serve",
    "dev": "rspack serve",
    "gpu:hud": "powershell -ExecutionPolicy Bypass -File scripts/gpu_hud_bridge.ps1",
    "build": "rspack --mode=production --node-env=production",
    "deploy": "gh-pages -d dist",
    "test": "vitest",
    "bench": "vitest bench --run",
    "perf:capture": "node ./scripts/cbt_perf_capture.mjs",
    "perf:matrix": "node ./scripts/cbt_perf_matrix.mjs",
    "bench:flight": "node ./scripts/bench_flight.mjs",
    "grain": "node ./scripts/grain_probe.mjs",
    "coverage": "vitest run --coverage",
    "pw": "node ./scripts/playwright_cli.mjs",
    "pw:help": "node ./scripts/playwright_cli.mjs --help",
    "pw:list": "node ./scripts/playwright_cli.mjs list",
    "pw:open": "node ./scripts/playwright_open_world42.mjs",
    "pw:validate": "node ./scripts/playwright_world42_smoke.mjs",
    "pw:world42:smoke": "node ./scripts/playwright_world42_smoke.mjs",
    "pw:snapshot": "node ./scripts/playwright_cli.mjs snapshot",
    "pw:screenshot": "node ./scripts/playwright_cli.mjs screenshot",
    "pw:trace:start": "node ./scripts/playwright_cli.mjs tracing-start",
    "pw:trace:stop": "node ./scripts/playwright_cli.mjs tracing-stop",
    "pw:console": "node ./scripts/playwright_cli.mjs console",
    "pw:network": "node ./scripts/playwright_cli.mjs network",
    "pw:install": "node ./scripts/playwright_cli.mjs install",
    "pw:install-browser": "node ./scripts/playwright_cli.mjs install-browser"
  },
  "devDependencies": {
    "@rsbuild/core": "^2.1.0",
    "@rspack/cli": "^2.1.0",
    "@rspack/core": "^2.1.0",
    "@tweakpane/core": "^2.0.5",
    "@types/node": "^26.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "@webgpu/types": "^0.1.71",
    "dotenv-webpack": "^9.0.0",
    "gh-pages": "^6.3.0",
    "html-webpack-plugin": "^5.6.7",
    "playwright": "^1.61.1",
    "ts-checker-rspack-plugin": "^1.5.1",
    "ts-shader-loader": "^2.0.2",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@babylonjs/core": "^9.14.0",
    "@babylonjs/gui": "^9.14.0",
    "@babylonjs/inspector": "^9.14.0",
    "@babylonjs/ktx2decoder": "^9.14.0",
    "@babylonjs/loaders": "^9.14.0",
    "@babylonjs/materials": "^9.14.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "tweakpane": "^4.0.5"
  }
}
