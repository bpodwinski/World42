{
  "name": "world42",
  "version": "0.0.5",
  "scripts": {
    "dev": "rspack serve",
    "build": "rspack --mode=production --node-env=production",
    "deploy": "gh-pages -d dist",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "pw": "node ./scripts/playwright_cli.mjs",
    "pw:help": "node ./scripts/playwright_cli.mjs --help",
    "pw:list": "node ./scripts/playwright_cli.mjs list",
    "pw:open": "node ./scripts/playwright_open_world42.mjs",
    "pw:world42:smoke": "node ./scripts/playwright_world42_smoke.mjs",
    "pw:snapshot": "node ./scripts/playwright_cli.mjs snapshot",
    "pw:screenshot": "node ./scripts/playwright_cli.mjs screenshot",
    "pw:trace:start": "node ./scripts/playwright_cli.mjs tracing-start",
    "pw:trace:stop": "node ./scripts/playwright_cli.mjs tracing-stop",
    "pw:console": "node ./scripts/playwright_cli.mjs console",
    "pw:network": "node ./scripts/playwright_cli.mjs network",
    "pw:install": "node ./scripts/playwright_cli.mjs install",
    "pw:install-browser": "node ./scripts/playwright_cli.mjs install-browser"
  },
  "devDependencies": {
    "@rsbuild/core": "^1.4.12",
    "@rspack/cli": "^1.5.8",
    "@rspack/core": "^1.5.8",
    "@types/node": "^24.9.2",
    "@vitest/coverage-v8": "^4.0.5",
    "dotenv-webpack": "^8.1.1",
    "gh-pages": "^6.3.0",
    "html-webpack-plugin": "^5.6.4",
    "ts-checker-rspack-plugin": "^1.1.6",
    "ts-shader-loader": "^2.0.2",
    "vitest": "^4.0.5"
  },
  "dependencies": {
    "@babylonjs/core": "^8.51.1",
    "@babylonjs/gui": "^8.51.1",
    "@babylonjs/inspector": "^8.51.1",
    "@babylonjs/ktx2decoder": "^8.51.1",
    "@babylonjs/loaders": "^8.51.1",
    "@babylonjs/materials": "^8.51.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3"
  }
}
