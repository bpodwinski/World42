{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "wasm: build (dev)",
            "type": "shell",
            "command": "wasm-pack",
            "args": [
                "build",
                "--dev",
                "--target",
                "bundler",
                "--out-dir",
                "pkg"
            ],
            "options": {
                "cwd": "${workspaceFolder}/terrain"
            },
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "wasm: build (release)",
            "type": "shell",
            "command": "wasm-pack",
            "args": [
                "build",
                "--release",
                "--target",
                "bundler",
                "--out-dir",
                "pkg"
            ],
            "options": {
                "cwd": "${workspaceFolder}/terrain"
            },
            "problemMatcher": [],
            "group": "build"
        }
    ]
}