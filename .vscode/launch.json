{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Dev",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "node",
      "program": "${workspaceFolder}/node_modules/@rspack/cli/bin/rspack.js",
      "args": ["serve"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "autoAttachChildProcesses": false,
      "env": {
        "NODE_ENV": "development",
        "PORT": "19000",
        "DEV_HOT": "0"
      },
      "preLaunchTask": "wasm: build (dev)"
    }
  ]
}
